{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vrs.local/contracts/candidate_alert.v1.schema.json",
  "title": "candidate_alert.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "alert_id",
    "event_id",
    "idempotency_key",
    "class_name",
    "severity",
    "start_pts_s",
    "peak_pts_s",
    "peak_frame_index",
    "source_runtime",
    "created_at",
    "peak_detections",
    "keyframe_pts",
    "num_keyframes",
    "evidence_refs"
  ],
  "properties": {
    "schema_version": { "const": "candidate_alert.v1" },
    "record_type": { "const": "candidate_alert" },
    "alert_id": { "type": "string", "minLength": 1 },
    "event_id": { "type": "string", "minLength": 1 },
    "idempotency_key": { "type": "string", "minLength": 1 },
    "stream_id": { "type": "string", "minLength": 1 },
    "source_id": { "type": "string", "minLength": 1 },
    "policy_id": { "type": "string", "minLength": 1 },
    "class_name": { "type": "string", "minLength": 1 },
    "severity": { "type": "string", "minLength": 1 },
    "start_pts_s": { "type": "number" },
    "peak_pts_s": { "type": "number" },
    "peak_frame_index": { "type": "integer" },
    "track_id": { "type": ["integer", "null"] },
    "source_runtime": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "peak_detections": {
      "type": "array",
      "items": { "$ref": "detection.v1.schema.json" }
    },
    "keyframe_pts": {
      "type": "array",
      "items": { "type": "number" }
    },
    "num_keyframes": { "type": "integer", "minimum": 0 },
    "evidence_refs": {
      "type": "array",
      "items": { "$ref": "evidence_ref.v1.schema.json" }
    }
  }
}
