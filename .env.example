# Copy this file to .env before running Docker Compose:
#   cp .env.example .env
#
# Docker Compose automatically reads .env from this directory and uses it for
# ${...} interpolation in docker-compose.yaml and optional override files.

# Local RTSP demo clip. Put custom MP4 files under ./clips and set this to the
# file name you want the Compose RTSP service to loop.
VRS_SAMPLE_CLIP=falldown_test.mp4
#
# Required for the default gated verifier model:
#   embedl/Cosmos-Reason2-2B-W4A16
#
# Use a Hugging Face token from an account that has accepted the model license
# and has access to the gated repository.
HF_TOKEN=hf_your_token_here

# Optional alias used by some Hugging Face tooling. Keep this equal to HF_TOKEN
# if you want both environment variable names available inside the container.
HUGGING_FACE_HUB_TOKEN=hf_your_token_here

# Optional host-side Hugging Face cache used only when
# docker-compose.hf-cache.yaml is enabled. The default keeps cache files inside
# the repository-local .cache directory.
VRS_HF_CACHE_DIR=./.cache/huggingface
