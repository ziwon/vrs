FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app

WORKDIR /app

RUN pip install --no-cache-dir \
    "fastapi>=0.110" \
    "uvicorn[standard]>=0.29" \
    "pillow>=10.2"

COPY vrs ./vrs
COPY scripts ./scripts

RUN mkdir -p /app/runs

EXPOSE 8000

CMD ["sh", "-c", "python scripts/make_fixture_runs.py --out /app/runs && uvicorn vrs.web.api:app --host 0.0.0.0 --port 8000"]
